// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  phone      String   @unique @db.VarChar(15)
  dob        String   @db.VarChar(100)
  role       String   @db.VarChar(30)
  name       String?  @db.VarChar(100)
  created_at DateTime @default(now())

  payment_requests PaymentRequest[] @relation("SupervisorRequests")
  approved_requests PaymentRequest[] @relation("PMApprovals")
  progress_updates ProjectProgress[]
  bills             Bill[]

  @@map("users")
}

model Project {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(100)
  description      String?           @db.Text
  status           String            @default("ACTIVE") @db.VarChar(20)
  expense_heads    String[]          @default([])
  requests         PaymentRequest[]
  progress_updates ProjectProgress[]
  archived_updates ArchivedProgress[]
  bills            Bill[]
  created_at       DateTime          @default(now())

  @@map("projects")
}

model ProjectProgress {
  id         Int      @id @default(autoincrement())
  percentage Int
  date       String   @db.VarChar(100) // Manual date format
  notes      String?  @db.Text
  project    Project  @relation(fields: [project_id], references: [id])
  project_id Int
  user       User     @relation(fields: [user_id], references: [id])
  user_id    Int
  created_at DateTime @default(now())

  @@map("project_progress")
}

model ArchivedProgress {
  id         Int      @id @default(autoincrement())
  percentage Int
  date       String   @db.VarChar(100)
  notes      String?  @db.Text
  project    Project  @relation(fields: [project_id], references: [id])
  project_id Int
  user_name  String   @db.VarChar(100)
  user_role  String   @db.VarChar(30)
  original_created_at DateTime
  archived_at DateTime @default(now())

  @@map("archived_progress")
}

enum PaymentStatus {
  PENDING_PM
  PENDING_ADMIN
  PAID
  REJECTED
}

model PaymentRequest {
  id           Int           @id @default(autoincrement())
  status       PaymentStatus @default(PENDING_PM)
  total_amount Decimal       @db.Decimal(10, 2)
  supervisor   User          @relation("SupervisorRequests", fields: [supervisor_id], references: [id])
  supervisor_id Int
  pm           User?         @relation("PMApprovals", fields: [pm_id], references: [id])
  pm_id        Int?
  project      Project       @relation(fields: [project_id], references: [id])
  project_id   Int
  materials    Material[]
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@map("payment_requests")
}

model Material {
  id         Int            @id @default(autoincrement())
  name       String         @db.VarChar(100)
  quantity   Int
  unit_price Decimal        @db.Decimal(10, 2)
  image_url  String?        @db.Text
  image_file_id String?     @db.Text
  request    PaymentRequest @relation(fields: [request_id], references: [id])
  request_id Int

  @@map("materials")
}

model Bill {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  image_url       String?  @db.Text
  image_file_id   String?  @db.Text
  project         Project  @relation(fields: [project_id], references: [id])
  project_id      Int
  creator         User     @relation(fields: [creator_id], references: [id])
  creator_id      Int
  created_at      DateTime @default(now())

  @@map("bills")
}
